    "from collections import Counter\n",
    "\n",
    "# Split the comma-separated strings and flatten the list of skills\n",
    "skills_list = df['required_skills'].dropna().str.split(', ')\n",
    "all_skills = [skill.strip() for sublist in skills_list for skill in sublist]\n",
    "skills_counter = Counter(all_skills)\n",
    "\n",
    "# Convert the top 10 most common skills into a DataFrame\n",
    "top_skills = pd.DataFrame(skills_counter.most_common(10), columns=['Skill', 'Job Count'])\n",
    "\n",
    "plt.figure(figsize=(10, 5))\n",
    "sns.barplot(data=top_skills, x='Job Count', y='Skill', palette='magma')\n",
    "\n",
    "plt.title('Top 10 Most In-Demand Skills in AI Job Postings')\n",
    "plt.xlabel('Number of Job Postings')\n",
    "plt.ylabel('Required Skill')\n",
    "plt.show()"
